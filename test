// ==UserScript==
// @name         Zampto Auto Renew (v3.5 Big UI)
// @namespace    http://tampermonkey.net/
// @version      3.5
// @description  基于 v3.4 核心：加大面板尺寸，增加日志显示行数，保留原生模拟点击逻辑
// @author       Gemini
// @match        https://dash.zampto.net/server?id=2574*
// @grant        none
// ==/UserScript==

(function() {
    'use strict';

    // --- 1. 配置 ---
    const CONFIG = {
        storageKey: 'zampto_v3_5_ui',
        btnText: "Renew Server",
        renewInterval: 24 * 60 * 60 * 1000 // 24小时
    };

    // --- 2. 状态管理 ---
    let data = JSON.parse(localStorage.getItem(CONFIG.storageKey)) || {
        nextRunTime: 0,
        status: 'idle', 
        logs: [],
        lastExpiryMinutes: 0
    };

    // --- 3. 核心点击函数 (模拟完整鼠标事件) ---
    function simulateClick(element) {
        if (!element) return;
        ['mouseover', 'mousedown', 'mouseup', 'click'].forEach(eventType => {
            const event = new MouseEvent(eventType, {
                bubbles: true,
                cancelable: true,
                view: window
            });
            element.dispatchEvent(event);
        });
    }

    // --- 4. 辅助：提取时间 ---
    function getCleanExpiryMinutes() {
        const elements = Array.from(document.querySelectorAll('p, div, span, li'));
        const target = elements.find(el => el.textContent.includes('Expiry') && !el.textContent.includes('function') && el.innerText.length < 150);
        if (!target) return 0;
        const text = target.innerText;
        let total = 0;
        text.replace(/(\d+)\s*day/g, (_, d) => total += d * 1440);
        text.replace(/(\d+)\s*h/g, (_, h) => total += h * 60);
        text.replace(/(\d+)\s*m/g, (_, m) => total += parseInt(m));
        return total;
    }

    function getExpiryDisplay() {
        const elements = Array.from(document.querySelectorAll('p, div, span, li'));
        const target = elements.find(el => el.textContent.includes('Expiry') && !el.textContent.includes('function'));
        return target ? target.innerText.replace('Expiry (Next Renewal):', '').trim() : "获取中...";
    }

    // --- 5. UI 面板 (已调整尺寸) ---
    const panel = document.createElement('div');
    // 修改点：width 改为 420px
    panel.style = "position:fixed;bottom:10px;right:10px;width:420px;background:#080808;color:#ccc;z-index:999999;border:1px solid #444;padding:12px;font-family:'Consolas', monospace;font-size:12px;box-shadow: 0 0 15px rgba(0,0,0,0.8);border-radius:5px;";
    
    panel.innerHTML = `
        <div style="border-bottom:1px solid #444;margin-bottom:8px;padding-bottom:5px;display:flex;justify-content:space-between;">
            <span style="font-weight:bold;color:#a78bfa;font-size:14px;">⚡ Zampto Monitor (v3.5)</span>
            <button id="kb-hide" style="background:none;border:none;color:#666;cursor:pointer;">[-]</button>
        </div>
        <div id="kb-content">
            <div id="kb-status" style="margin-bottom:8px;color:#fff;font-size:13px;background:#222;padding:5px;border-radius:3px;">初始化...</div>
            <div style="margin-bottom:8px;display:flex;gap:10px;">
                <button id="kb-reset" style="background:#dc3545;color:white;border:none;padding:5px 12px;cursor:pointer;border-radius:3px;font-weight:bold;">重置并运行</button>
                <button id="kb-pause" style="background:#ffc107;color:black;border:none;padding:5px 12px;cursor:pointer;border-radius:3px;font-weight:bold;">暂停</button>
            </div>
            <div id="kb-logs" style="height:400px;overflow-y:auto;border:1px solid #333;padding:8px;background:#000;border-radius:3px;"></div>
        </div>
    `;
    document.body.appendChild(panel);

    function log(msg, color = "#aaa") {
        const time = new Date().toLocaleTimeString();
        // 增加日志显示数量上限到 80 条
        data.logs.unshift(`<div style="color:${color};margin-bottom:3px;border-bottom:1px dashed #222;padding-bottom:2px;"><span style="color:#555">[${time}]</span> ${msg}</div>`);
        if (data.logs.length > 80) data.logs.pop();
        localStorage.setItem(CONFIG.storageKey, JSON.stringify(data));
        renderLogs();
    }
    
    function renderLogs() {
         const logDiv = document.getElementById('kb-logs');
         if(logDiv) logDiv.innerHTML = data.logs.join('');
    }

    function updateStatus(text) { 
        const el = document.getElementById('kb-status');
        if(el) el.innerHTML = text; 
    }

    // --- 6. 核心逻辑 ---

    function checkResult() {
        const currentMinutes = getCleanExpiryMinutes();
        if (currentMinutes > data.lastExpiryMinutes || currentMinutes > 2000) {
            log(`✅ 续期成功! 当前有效期: ${getExpiryDisplay()}`, "#2ecc71");
            data.status = 'idle';
            data.nextRunTime = Date.now() + CONFIG.renewInterval;
            localStorage.setItem(CONFIG.storageKey, JSON.stringify(data));
        } else {
            log("⚠️ 时间未更新，等待下轮 (60s后) 重试...", "#e67e22");
            data.status = 'idle'; 
            data.nextRunTime = Date.now() + 60000; 
            localStorage.setItem(CONFIG.storageKey, JSON.stringify(data));
        }
    }

    async function executeRenew() {
        const minutes = getCleanExpiryMinutes();
        data.lastExpiryMinutes = minutes; 
        data.status = 'checking'; 
        localStorage.setItem(CONFIG.storageKey, JSON.stringify(data));

        log(`🖱️ 准备点击... (当前: ${getExpiryDisplay()})`, "#3498db");
        
        const btn = Array.from(document.querySelectorAll('button, a')).find(el => el.textContent.includes(CONFIG.btnText));
        
        if (btn) {
            simulateClick(btn);
            log("🚀 已触发点击动作 (SimulateClick)", "#9b59b6");
            
            await new Promise(r => setTimeout(r, 10000));
            log("👀 点击后10秒自检...", "#3498db");
            checkResult();
        } else {
            log("❌ 未找到 Renew 按钮", "#e74c3c");
            data.status = 'idle';
        }
    }

    // 主循环
    let isPaused = false;
    setInterval(() => {
        if (isPaused) { updateStatus("🔴 脚本已暂停"); return; }
        
        const now = Date.now();
        
        if (data.status === 'checking') {
            updateStatus("🔎 正在验证上一次点击结果...");
            checkResult();
            return;
        }

        if (now < data.nextRunTime) {
            const diff = data.nextRunTime - now;
            const h = Math.floor(diff / 3600000);
            const m = Math.floor((diff % 3600000) / 60000);
            const s = Math.floor((diff % 60000) / 1000);
            updateStatus(`⏳ 下次续期: ${h}h ${m}m ${s}s`);
            return;
        }

        updateStatus("⚙️ 正在执行续期...");
        executeRenew();

    }, 2000);

    // 交互绑定
    renderLogs();
    
    document.getElementById('kb-reset').onclick = () => {
        data = { nextRunTime: 0, status: 'idle', logs: [], lastExpiryMinutes: 0 };
        localStorage.setItem(CONFIG.storageKey, JSON.stringify(data));
        location.reload();
    };
    
    document.getElementById('kb-pause').onclick = function() {
        isPaused = !isPaused;
        this.innerText = isPaused ? "恢复" : "暂停";
    };
    
    document.getElementById('kb-hide').onclick = () => {
        const content = document.getElementById('kb-content');
        content.style.display = content.style.display === 'none' ? 'block' : 'none';
    };

    log("🤖 大屏监控模式已就绪 (v3.5)", "#fff");

})();
